# Kanban server configuration
# Copy this file to .opencode/.env and adjust as needed.
# This file is never committed (.opencode/.env is gitignored via the root .env rule).

# Port the Kanban HTTP server listens on (dashboard + REST API).
KANBAN_HTTP_PORT=8765

# Port OpenCode is listening on (--port flag passed to opencode at launch).
# MANDATORY: OpenCode must be started with `opencode --port <OPENCODE_PORT>`.
OPENCODE_PORT=4096

# Full URL override (takes precedence over OPENCODE_PORT).
# Only set this if OpenCode runs on a different host or non-standard path.
# OPENCODE_SERVER_URL=http://localhost:4096

# Set to 0 to disable automatic command injection into OpenCode on card drag.
# OPENCODE_TRIGGER_ENABLED=1

# Set to 1 to enable verbose MCP call logging to stderr and kanban.log.
# KANBAN_DEBUG=0

# Application title shown in the navbar and browser tab.
# Defaults to "Kanban" if not set.
APP_TITLE=News Briefing SaaS

# Figma MCP — Personal Access Token (Settings → Security → Personal access tokens)
# Requires scope: File content (read-only)
# FIGMA_API_KEY=figd_...

# ─────────────────────────────────────────────────────────────────
# JIRA ↔ Kanban integration (optional — see JIRA.md)
# The whole mechanism is OFF unless JIRA_SYNC_ENABLED=1.
# ─────────────────────────────────────────────────────────────────

# ── Connexion JIRA ──
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_USER_EMAIL=prenom.nom@company.com
# JIRA_API_TOKEN=your_api_token_here        # généré sur id.atlassian.com

# ── Identité : le dev ne voit que SES tickets ──
# JIRA_MY_ACCOUNT_ID=a1b2c3d4e5f6           # accountId JIRA du propriétaire

# ── Projet & Board ──
# JIRA_BOARD_ID=123
# JIRA_PROJECT_KEY=PROJ

# ── Signal d'entrée : statut JIRA qui crée une US locale absente ──
# JIRA_PULL_TRIGGER_STATUS=DEV IN PROGRESS

# ── Sync behavior (désactivable) ──
# JIRA_SYNC_ENABLED=0                        # master switch (pull)
# JIRA_WRITEBACK_ENABLED=0                   # commentaires Kanban → JIRA
# JIRA_POLL_INTERVAL_SECONDS=120
